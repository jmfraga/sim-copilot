# Proveedor de razonamiento (default: Anthropic)
ANTHROPIC_API_KEY=
REASONING_BASE_URL=https://api.anthropic.com
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_STRONG=claude-sonnet-4-6

# Proveedor de transcripción (endpoint estilo OpenAI /audio/transcriptions)
OPENAI_API_KEY=
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1

# Para ver la demo desde otra máquina de la red (dev server): IPs/hosts permitidos, coma-separados
ALLOWED_DEV_ORIGINS=
